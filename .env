# Server
PORT=8000
NODE_ENV=development

# MySQL - Đổi 127.0.0.1 thành tên service: mysql-db
MYSQL_HOST=mysql-db
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=root
MYSQL_DB=auction_db

# Redis - Đổi 127.0.0.1 thành tên service: redis-cache
REDIS_HOST=redis-cache
REDIS_PORT=6379

# Kafka - Đổi localhost thành tên service: kafka
KAFKA_BROKER=kafka:29092

# JWT
JWT_SECRET=your_super_secret_key_here
JWT_EXPIRES_IN=7d