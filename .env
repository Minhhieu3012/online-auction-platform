# Server
PORT=8000
NODE_ENV=development

# MySQL - Đổi 127.0.0.1 thành tên service: mysql-db (HIỆN TẠI: Dùng localhost để test Uvicorn)
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=root
MYSQL_DB=auction_db

# Redis - Đổi 127.0.0.1 thành tên service: redis-cache (HIỆN TẠI: Dùng localhost để test Uvicorn)
REDIS_HOST=localhost
REDIS_PORT=6379

# Kafka - Đổi localhost thành tên service: kafka (HIỆN TẠI: Dùng localhost:9092 để test Uvicorn)
KAFKA_BROKER=localhost:9092

# JWT
JWT_SECRET=your_super_secret_key_here
JWT_EXPIRES_IN=7d